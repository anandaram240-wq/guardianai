# ═══════════════════════════════════════════════════════
# GuardianAI — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Supabase (Free tier) ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Server ──
DOMAIN=your-oracle-vm-ip-or-domain.com
JWT_SECRET=generate-a-random-64-char-string-here
PORT=3001
NODE_ENV=production

# ── ntfy.sh (Push Notifications) ──
NTFY_URL=http://ntfy:80
NTFY_TOPIC_SECRET=generate-random-secret

# ── Coturn (WebRTC TURN relay) ──
TURN_USERNAME=guardianai
TURN_PASSWORD=change-this-strong-password-here

# ── AdGuard Home ──
ADGUARD_URL=http://adguardhome:3000
ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=change-this-too
